# Required: OpenAI API Key for LLM agents
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Optional: Serper API for Google job search (falls back to mock data if not set)
SERPER_API_KEY=your_serper_api_key_here

# Optional: Gmail for sending applications and monitoring responses
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Safety: Require approval before sending emails (recommended: true)
REQUIRE_APPROVAL=true

# Limits
MAX_APPLICATIONS_PER_RUN=5
EMAIL_CHECK_INTERVAL=60

# Optional: WhatsApp notifications
# WHATSAPP_TOKEN=your_whatsapp_token
# WHATSAPP_PHONE_ID=your_phone_id
# WHATSAPP_TO=recipient_phone_number
